# ─────────────────────────────────────────────────────────────
# Database — Neon Postgres
# Use the DIRECT (unpooled) endpoint in dev for reliable schema push.
# Use the pooled endpoint (-pooler) for serverless production runtime.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─────────────────────────────────────────────────────────────
# Payload
# ─────────────────────────────────────────────────────────────
PAYLOAD_SECRET=generate-with-openssl-rand-hex-32
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Vercel Blob (file storage) — leave blank locally (falls back to disk)
# ─────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────
# Stripe (Phase 5)
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# Currency / FX (Phase 5) — base currency + fallback USD rate
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_CURRENCY=BDT
USD_TO_BDT_RATE=120

# ─────────────────────────────────────────────────────────────
# Email — Resend (Phase 5)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────
# Seed admin (Phase 0)
# ─────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@sajda.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ADMIN_NAME=Sajda Admin
